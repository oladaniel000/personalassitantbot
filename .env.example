# ─── TELEGRAM ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_from_BotFather

# ─── GOOGLE OAUTH ───────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_client_id_from_google_cloud_console
GOOGLE_CLIENT_SECRET=your_client_secret_from_google_cloud_console
# Leave redirect as-is — uses the "copy-paste code" flow (no web server needed)
GOOGLE_REDIRECT_URI=urn:ietf:wg:oauth:2.0:oob

# ─── COMMUTE (free key from openrouteservice.org) ───────────────────────────────
ORS_API_KEY=your_free_openrouteservice_api_key

# ─── USER DEFAULTS ──────────────────────────────────────────────────────────────
# Standard tz database name, e.g. Africa/Lagos, Europe/London, America/New_York
USER_TIMEZONE=Africa/Lagos
MORNING_SUMMARY_TIME=07:00
EVENING_RECAP_TIME=21:00
